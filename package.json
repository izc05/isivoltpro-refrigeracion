{
  "name": "isivoltpro-refrigeracion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "data:generate": "python scripts/generate_refrigerant_data.py",
    "cap:sync": "npm run build && npx cap sync android",
    "android:debug": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease",
    "android:aab:release": "npm run cap:sync && cd android && gradlew.bat bundleRelease",
    "data:generate:uv": "uv run --python 3.12 --with CoolProp==6.8.0 python scripts/generate_refrigerant_data.py"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@hookform/resolvers": "^5.4.0",
    "dexie": "^4.4.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.21.0",
    "psychrolib": "^1.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "vite-plugin-pwa": "^1.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
